{
  "expo": {
    "name": "PawDigi",
    "slug": "pawdigi-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/logo.jpg",
    "userInterfaceStyle": "light",
    "splash": {
      "image": "./assets/logo.jpg",
      "resizeMode": "contain",
      "backgroundColor": "#F1FAFA"
    },
    "assetBundlePatterns": [
      "**/*"
    ],
    "plugins": [
      "./plugins/withApkFilename",
      [
        "expo-local-authentication",
        {
          "faceIDPermission": "Allow PawDigi to use Face ID to protect your records."
        }
      ]
    ],
    "ios": {
      "supportsTablet": true
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/logo.jpg",
        "backgroundColor": "#F1FAFA"
      },
      "package": "com.debarunlahiri.pawdigimobile"
    },
    "web": {
      "favicon": "./assets/logo.jpg"
    }
  }
}
